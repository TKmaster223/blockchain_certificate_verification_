# Database Configuration
MONGO_URI=mongodb://localhost:27017
DB_NAME=cert_verification

# JWT Authentication
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256

# Initial Admin Setup (for setup_admin.py script)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@certificate-system.com
ADMIN_PASSWORD=admin123456

# Blockchain Configuration
BLOCKCHAIN_NODE=http://localhost:8545
CONTRACT_ADDRESS=

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Frontend Configuration (if needed)
VITE_API_URL=http://localhost:8000

# Security Warning:
# NEVER commit real secrets to version control!
# This file should be copied to .env and modified with real values
# The .env file is gitignored to prevent accidental commits
# CHANGE ALL DEFAULT PASSWORDS IN PRODUCTION!
